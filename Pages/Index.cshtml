                <button id="sm-confirm-del-btn" class="btn btn-danger" onclick="ShopMgmt.executeDelete()">
                    &#x1F5D1;&#xFE0F; Delete
                </button>
            </div>
        </div>
    </div>

    <!-- --- PET PHOTO VIEWER MODAL -------------------------------------------------------- -->
    <div id="photo-modal" class="modal-bg" style="display:none">
        <div class="modal-sheet" style="text-align:center;padding:16px 16px 20px">
            <div class="modal-handle"></div>
            <div id="photo-modal-title" style="font-size:16px;font-weight:700;margin-bottom:14px">&#x1F5BC;&#xFE0F; Pet Photo</div>
            <div style="border-radius:14px;overflow:hidden;background:var(--sf2);
                        min-height:80px;display:flex;align-items:center;justify-content:center;
                        margin-bottom:14px">
                <img id="photo-modal-img" src="" alt="Pet photo"
                     style="max-width:100%;max-height:60vh;object-fit:contain;display:block;border-radius:12px">
            </div>
            <div id="photo-modal-err"
                 style="display:none;color:var(--er);font-size:13px;margin-bottom:12px;line-height:19px"></div>
            <button class="btn btn-ghost" onclick="closePetPhotoModal()">&#x2715; Close</button>
        </div>
    </div>

    <!-- --- BREEDING CONTACT MODAL --------------------------------------- -->
    <div id="breed-modal" class="modal-bg" style="display:none">
        <div class="modal-sheet">
            <div class="modal-handle"></div>
            <div style="display:flex;gap:13px;align-items:center;margin-bottom:17px">
                <div style="width:58px;height:58px;border-radius:15px;background:var(--or-p);
                            display:flex;align-items:center;justify-content:center;font-size:28px"
                     id="breed-modal-icon">&#x1F43E;</div>
                <div>
                    <div id="breed-modal-name" style="font-size:17px;font-weight:700"></div>
                    <div id="breed-modal-sub"  style="font-size:13px;color:var(--tx2)"></div>
                    <span class="badge badge-or">&#x1F49E; Available for breeding</span>
                </div>
            </div>
            <div class="card"><div id="breed-modal-details"></div></div>
            <div style="background:var(--ok-p);border-radius:10px;padding:11px 13px;margin-top:12px;
                        font-size:12px;color:#065F46;line-height:18px">
                &#x2139;&#xFE0F; Owner details are shared with their consent. Please be respectful and responsible.
            </div>
            <div class="d-row mt-8">
                <button id="breed-modal-contact" class="btn btn-primary">&#x1F4E9; Send Interest</button>
                <button class="btn btn-ghost" onclick="closeBreedingModal()">Close</button>
            </div>
        </div>
    </div>

    <!-- --- REPORT COMMENTS MODAL ---------------------------------------- -->
    <div id="rc-modal" class="modal-bg" style="display:none">
        <div class="modal-sheet">
            <div class="modal-handle"></div>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px">
                <div style="font-size:16px;font-weight:700">&#x1F4AC; Report Comments</div>
                <button style="background:none;border:none;font-size:20px;color:var(--tx3);cursor:pointer;line-height:1"
                    onclick="closeReportCommentsModal()">&times;</button>
            </div>
            <div id="rc-report-summary"
                 style="font-size:12px;color:var(--tx2);margin-bottom:14px;padding:8px 10px;
                        background:var(--sf2);border-radius:8px;line-height:18px"></div>
            <!-- existing comments list -->
            <div id="rc-comments-list"
                 class="scroll"
                 style="max-height:40vh;overflow-y:auto;margin-bottom:14px;
                        border:1px solid var(--bd);border-radius:10px;padding:10px;
                        display:flex;flex-direction:column;gap:10px">
            </div>
            <!-- add / edit comment form -->
            <div style="font-size:11px;font-weight:700;color:var(--tx2);text-transform:uppercase;
                        letter-spacing:.5px;margin-bottom:6px" id="rc-form-label">Add Comment</div>
            <div id="rc-comment-err"
                 style="color:var(--er);font-size:11px;font-weight:600;display:none;margin-bottom:6px"></div>
            <textarea id="rc-comment-input" class="field-input"
                placeholder="Type your comment here…" rows="3"
                style="resize:vertical;font-size:13px"></textarea>
            <div class="d-row" style="margin-top:10px">
                <button class="btn btn-ghost" id="rc-cancel-edit-btn"
                    style="display:none" onclick="rcCancelEdit()">Cancel edit</button>
                <button class="btn btn-primary" id="rc-save-btn"
                    onclick="rcSaveComment()">&#x1F4BE; Save Comment</button>
            </div>
        </div>
    </div>

</div>

@section Scripts {
<script>
    // Augment AFP.go: screen lifecycle hooks
    const _origGo = AFP.go;
    const _patchedGo = function(screen) {
        if (screen === 'petProfile') {
            // petProfile manages its own DOM visibility inside loadPetProfile()
            loadPetProfile();
            return;
        }
        _origGo(screen);
        if (screen === 'newPet')        { setTimeout(initNewPet,        50); }
        if (screen === 'reportPet')     { setTimeout(initReportPet,     50); }
        if (screen === 'renew')         { setTimeout(initRenew,         50); }
        if (screen === 'newOwner')      { setTimeout(initNewOwner,      50); }
        if (screen === 'forum')         { setTimeout(() => Forum.loadForum(), 50); }
        if (screen === 'searchDoctor')  { setTimeout(loadSearchDoctor,  50); }
        if (screen === 'searchShop')    { setTimeout(loadSearchShop,    50); }
        if (screen === 'breedingMatch') { setTimeout(loadBreedingMatch, 50); }
        if (screen === 'microchip')     { setTimeout(loadMicrochip,     50); }
    };
    Object.defineProperty(AFP, 'go', { get: () => _patchedGo });
</script>
}
