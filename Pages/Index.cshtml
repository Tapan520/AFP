@page
@model IndexModel
@{
    Layout = "_AppLayout";
}

<div class="afp-app">

    <!-- --- SCREEN: SPLASH ---------------------------------------------- -->
    <div id="screen-splash" class="afp-screen screen splash d-none">
        <div class="splash-logo">&#x1F43E;</div>
        <h1>All For Pets</h1>
        <p>Register, manage and track your pets<br>with your city municipality</p>
        <div class="splash-btns">
            <button class="btn btn-dark" onclick="AFP.go('register')">&#x1F436;&nbsp; Register</button>
            <button class="btn btn-dark" onclick="AFP.go('login')">&#x1F511;&nbsp; Login</button>
            <button class="splash-staff-link" onclick="AFP.go('adminLogin')">&#x1F3DB;&#xFE0F;&nbsp; Municipal Staff Login</button>
        </div>
        <!-- <div class="splash-footer">Jaipur � Delhi � Mumbai</div>-->
    </div>

    <!-- --- SCREEN: LOGIN ----------------------------------------------- -->
    <div id="screen-login" class="afp-screen screen d-none">
        <div class="topbar">
            <div class="topbar-left">
                <button class="back-btn" onclick="AFP.go('splash')">&#x2190;</button>
                <span class="topbar-title">Login</span>
            </div>
            <div style="width:34px"></div>
        </div>
        <div class="scroll p-18 pb-32">
            <div class="auth-h">Welcome back</div>
            <div class="auth-sub">Login to manage your pets</div>
            <div id="login-err"></div>
            <form id="login-form" novalidate>
                <div class="field">
                    <label class="field-label">Mobile or Email</label>
                    <input id="login-id" class="field-input" type="text" placeholder="Mobile or email" autocomplete="username" />
                </div>
                <div class="field">
                    <label class="field-label">Password</label>
                    <input id="login-pw" class="field-input" type="password" placeholder="Password" autocomplete="current-password" />
                </div>
                <button id="login-btn" type="submit" class="btn btn-primary">Login &#x2192;</button>
            </form>
            <div class="auth-sw">
                <span>New here?&nbsp;</span>
                <a href="javascript:void(0)" onclick="AFP.go('register')">Create account</a>
            </div>
        </div>
    </div>

    <!-- --- SCREEN: REGISTER -------------------------------------------- -->
    <div id="screen-register" class="afp-screen screen d-none">
        <div class="topbar">
            <div class="topbar-left">
                <button class="back-btn" onclick="AFP.go('splash')">&#x2190;</button>
                <span class="topbar-title">Create Account</span>
            </div>
            <div style="width:34px"></div>
        </div>
        <div class="scroll p-18 pb-32">
            <div class="alert-box alert-info"><span>&#x2139;&#xFE0F;</span><p>Your account links to your ward for pet licensing.</p></div>
            <div id="reg-err"></div>
            <form id="reg-form" novalidate>
                <div class="field"><label class="field-label">Full name *</label><input id="reg-name" class="field-input" placeholder="Tapan Singh" /></div>
                <div class="field"><label class="field-label">Mobile *</label><input id="reg-mob" class="field-input" type="tel" placeholder="9810******" /></div>
                <div class="field"><label class="field-label">Email *</label><input id="reg-email" class="field-input" type="email" placeholder="user@email.com" /></div>
                <div class="field"><label class="field-label">Address *</label><input id="reg-addr" class="field-input" placeholder="House No, Street, Area" /></div>
                <div class="field">
                    <label class="field-label">City *</label>
                    <select id="reg-city" class="field-input"><option value="">Select city…</option></select>
                </div>
                <div class="field">
                    <label class="field-label">Nigam *</label>
                    <select id="reg-nigam" class="field-input"><option value="">Select nigam…</option></select>
                </div>
                <div class="field" id="reg-zone-field" style="display:none">
                    <label class="field-label">Zone *</label>
                    <select id="reg-zone" class="field-input"><option value="">Select zone…</option></select>
                </div>
                <div class="field" id="reg-ward-field" style="display:none">
                    <label class="field-label">Ward *</label>
                    <select id="reg-ward" class="field-input"><option value="">Select ward…</option></select>
                </div>
                <div class="field"><label class="field-label">Password *</label><input id="reg-pw" class="field-input" type="password" placeholder="Create a password" autocomplete="new-password" /></div>
                <button id="reg-btn" type="submit" class="btn btn-primary">Create Account &#x2192;</button>
            </form>
            <div class="auth-sw">
                <span>Have account?&nbsp;</span>
                <a href="javascript:void(0)" onclick="AFP.go('login')">Login</a>
            </div>
        </div>
    </div>

    <!-- --- SCREEN: ADMIN LOGIN ------------------------------------------ -->
    <div id="screen-adminLogin" class="afp-screen screen d-none">
        <div style="background:var(--dk);padding:28px 18px;text-align:center;flex-shrink:0">
            <div style="width:72px;height:72px;border-radius:20px;background:rgba(232,103,10,.2);display:flex;align-items:center;justify-content:center;font-size:32px;margin:0 auto 10px">&#x1F3DB;&#xFE0F;</div>
            <div style="color:#fff;font-size:20px;font-weight:700">Municipal Portal</div>
            <div style="color:#9A958C;font-size:13px;margin-top:4px">For authorised municipal officers only</div>
        </div>
        <div class="scroll p-18 pb-32">
            <div id="al-err"></div>
            <form id="adminlogin-form" novalidate>
                <div class="field"><label class="field-label">Staff ID / Email</label><input id="al-id" class="field-input" placeholder="staff@jaipur.gov.in" /></div>
                <div class="field"><label class="field-label">Password</label><input id="al-pw" class="field-input" type="password" placeholder="Password" /></div>
                <button id="al-btn" type="submit" class="btn btn-primary">Login to Municipal Portal &#x2192;</button>
            </form>
            <div style="height:10px"></div>
            <button class="btn btn-ghost" onclick="AFP.go('splash')">&#x2190; Back to Citizen App</button>
        </div>
    </div>

    <!-- --- SCREEN: DASHBOARD -------------------------------------------- -->
    <div id="screen-dashboard" class="afp-screen screen d-none">
        <div class="topbar">
            <div class="topbar-left">
                <div class="topbar-logo">&#x1F43E;</div>
                <span class="topbar-title">All For Pets</span>
            </div>
            <div style="display:flex;align-items:center;gap:6px">
                <div class="notif-badge-wrap">
                    <button class="icon-btn" onclick="AFP.go('notifications')" title="Notifications">&#x1F514;</button>
                    <div id="notif-badge" class="notif-badge">0</div>
                </div>
                <button class="icon-btn" title="Logout" onclick="AFP.logout()">&#x1F6AA;</button>
            </div>
        </div>
        <div id="dashboard-body" class="scroll" style="padding-bottom:24px"></div>
    </div>

    <!-- --- SCREEN: SEARCH PET ------------------------------------------- -->
    <div id="screen-searchPet" class="afp-screen screen d-none">
        <div class="topbar">
            <div class="topbar-left">
                <div class="topbar-logo">&#x1F43E;</div>
                <span class="topbar-title">Search Pet</span>
            </div>
            <button class="icon-btn" title="Logout" onclick="AFP.logout()">&#x1F6AA;</button>
        </div>
        <div style="padding:13px;background:#fff;border-bottom:1px solid var(--bd)">
            <div class="search-wrap">
                <span class="search-icon">&#x1F50D;</span>
                <input id="searchpet-q" class="field-input" placeholder="Pet name, owner, Pet ID�"
                    oninput="doSearchPet()" style="padding-left:34px" />
            </div>
            <div class="chips">
                <button class="chip searchpet-chip active" data-flt="all" onclick="setSearchFilter(this,'all')">All</button>
                <button class="chip searchpet-chip" data-flt="dog" onclick="setSearchFilter(this,'dog')">&#x1F436; Dogs</button>
                <button class="chip searchpet-chip" data-flt="cat" onclick="setSearchFilter(this,'cat')">&#x1F431; Cats</button>
                <button class="chip searchpet-chip" data-flt="other" onclick="setSearchFilter(this,'other')">&#x1F43E; Others</button>
            </div>
        </div>
        <div id="search-results" class="scroll" style="padding:13px"></div>
        <div id="search-body"></div>
    </div>


    <!-- --- SCREEN: NOTIFICATIONS --------------------------------------- -->
    <div id="screen-notifications" class="afp-screen screen d-none">
        <div class="topbar">
            <div class="topbar-left">
                <button class="back-btn" onclick="AFP.go('dashboard')">&#x2190;</button>
                <span class="topbar-title">&#x1F514; Notifications</span>
            </div>
            <button class="icon-btn" title="Logout" onclick="AFP.logout()">&#x1F6AA;</button>
        </div>
        <div id="notif-body" class="scroll" style="padding-bottom:24px"></div>
    </div>

    <!-- --- SCREEN: VACCINE REMINDERS ----------------------------------- -->
    <div id="screen-vaxReminders" class="afp-screen screen d-none">
        <div class="topbar">
            <div class="topbar-left">
                <button class="back-btn" onclick="AFP.go('dashboard')">&#x2190;</button>
                <span class="topbar-title">&#x1F489; Vaccine Reminders</span>
            </div>
            <button class="icon-btn" title="Logout" onclick="AFP.logout()">&#x1F6AA;</button>
        </div>
        <div id="vax-reminder-body" class="scroll" style="padding-bottom:24px"></div>
    </div>

    <!-- --- SCREEN: ADOPTION CENTER ------------------------------------- -->
    <div id="screen-adoption" class="afp-screen screen d-none">
        <div class="topbar">
            <div class="topbar-left">
                <button class="back-btn" onclick="AFP.go('dashboard')">&#x2190;</button>
                <span class="topbar-title">&#x1F43E; Pet Adoption</span>
            </div>
            <button class="icon-btn" title="Logout" onclick="AFP.logout()">&#x1F6AA;</button>
        </div>
        <div id="adoption-body" class="scroll" style="padding-bottom:24px"></div>
    </div>

    <!-- --- SCREEN: LOST & FOUND ---------------------------------------- -->
    <div id="screen-lostFound" class="afp-screen screen d-none">
        <div class="topbar">
            <div class="topbar-left">
                <button class="back-btn" onclick="AFP.go('dashboard')">&#x2190;</button>
                <span class="topbar-title">&#x1F50D; Lost &amp; Found</span>
            </div>
            <button class="icon-btn" title="Logout" onclick="AFP.logout()">&#x1F6AA;</button>
        </div>
        <div id="lostfound-body" class="scroll" style="padding-bottom:24px"></div>
    </div>

    <!-- --- SCREEN: EMERGENCY VET --------------------------------------- -->
    <div id="screen-emergencyVet" class="afp-screen screen d-none">
        <div class="topbar">
            <div class="topbar-left">
                <button class="back-btn" onclick="AFP.go('dashboard')">&#x2190;</button>
                <span class="topbar-title">&#x1F6A8; Emergency Vet</span>
            </div>
            <button class="icon-btn" title="Logout" onclick="AFP.logout()">&#x1F6AA;</button>
        </div>
        <div id="emergency-body" class="scroll" style="padding-bottom:24px"></div>
    </div>

    <!-- --- SCREEN: MICROCHIP LOOKUP ------------------------------------ -->
    <div id="screen-microchip" class="afp-screen screen d-none">
        <div class="topbar">
            <div class="topbar-left">
                <button class="back-btn" onclick="AFP.go('dashboard')">&#x2190;</button>
                <span class="topbar-title">&#x1F4F2; Microchip Lookup</span>
            </div>
            <button class="icon-btn" title="Logout" onclick="AFP.logout()">&#x1F6AA;</button>
        </div>
        <div id="microchip-body" class="scroll" style="padding-bottom:24px"></div>
    </div>

    <!-- --- SCREEN: EVENTS ---------------------------------------------- -->
    <div id="screen-events" class="afp-screen screen d-none">
        <div class="topbar">
            <div class="topbar-left">
                <button class="back-btn" onclick="AFP.go('dashboard')">&#x2190;</button>
                <span class="topbar-title">&#x1F4C5; Community Events</span>
            </div>
            <button class="icon-btn" title="Logout" onclick="AFP.logout()">&#x1F6AA;</button>
        </div>
        <div id="events-body" class="scroll" style="padding-bottom:24px"></div>
    </div>

    <!-- --- SCREEN: PROFILE ---------------------------------------------- -->
    <div id="screen-profile" class="afp-screen screen d-none">
        <div class="profile-hdr">
            <div class="profile-avatar">&#x1F464;</div>
            <div id="profile-name" class="profile-name"></div>
            <div id="profile-id" class="profile-id"></div>
            <span class="badge badge-ok">&#x2705; Verified owner</span>
        </div>
        <div class="tabs">
            <button class="tab active" data-tab="details" onclick="profileSetTab('details')">My Details</button>
            <button class="tab" data-tab="pets" onclick="profileSetTab('pets')">My Pets</button>
            <button class="tab" data-tab="docs" onclick="profileSetTab('docs')">Documents</button>
        </div>
        <div id="profile-body" class="scroll p-18 pb-32"></div>
        <div class="bnav">
            <div class="bnav-item" onclick="AFP.go('dashboard')"><span class="bnav-icon">&#x1F3E0;</span><span class="bnav-lbl">Home</span></div>
            <div class="bnav-item" onclick="AFP.go('searchPet')"><span class="bnav-icon">&#x1F50D;</span><span class="bnav-lbl">Search</span></div>
            <div class="bnav-item active"><span class="bnav-icon">&#x1F464;</span><span class="bnav-lbl">Profile</span></div>
        </div>
    </div>

    <!-- --- SCREEN: PET PROFILE ------------------------------------------ -->
    <div id="screen-petProfile" class="afp-screen screen d-none">
        <div class="topbar">
            <div class="topbar-left">
                <button class="back-btn" onclick="AFP.go('dashboard')">&#x2190;</button>
                <span class="topbar-title">Pet Profile</span>
            </div>
            <button class="icon-btn" title="Logout" onclick="AFP.logout()">&#x1F6AA;</button>
        </div>
        <div style="display:flex;align-items:center;gap:17px;padding:18px;background:var(--or-p);border-bottom:1px solid var(--bd);flex-shrink:0">
            <div class="pet-photo-ring">
                <div style="width:74px;height:74px;border-radius:18px;background:#fff;display:flex;align-items:center;justify-content:center;border:2px solid var(--bd)">
                    <span id="petprofile-icon" style="font-size:34px">&#x1F43E;</span>
                </div>
            </div>
            <div style="flex:1">
                <div id="petprofile-name" style="font-size:20px;font-weight:700;margin-bottom:4px"></div>
                <div id="petprofile-sub" style="font-size:13px;color:var(--tx2);margin-bottom:7px"></div>
                <div id="petprofile-badge"></div>
            </div>
        </div>
        <div id="petprofile-vaxbanner" class="vax-alert" style="display:none"></div>
        <div class="tabs">
            <button class="tab active" data-tab="details" onclick="petProfileSetTab('details')">Details</button>
            <button class="tab" data-tab="health" onclick="petProfileSetTab('health')">Health</button>
            <button class="tab" data-tab="docs" onclick="petProfileSetTab('docs')">Documents</button>
        </div>
        <div id="petprofile-body" class="scroll p-18 pb-32"></div>
    </div>

    <!-- --- SCREEN: NEW PET ---------------------------------------------- -->
    <div id="screen-newPet" class="afp-screen screen d-none">
        <div class="topbar">
            <div class="topbar-left">
                <button class="back-btn" onclick="AFP.go('dashboard')">&#x2190;</button>
                <span class="topbar-title">Register New Pet</span>
            </div>
            <button class="icon-btn" title="Logout" onclick="AFP.logout()">&#x1F6AA;</button>
        </div>
        <div class="scroll p-18 pb-32">
            <div class="alert-box alert-info"><span>&#x2139;&#xFE0F;</span><p>Ward officer reviews within 2�3 working days.</p></div>
            <div id="np-err"></div>
            <form id="newpet-form" novalidate>
                <div class="field"><label class="field-label">Pet name *</label><input id="np-name" class="field-input" placeholder="e.g. Bruno" /></div>
                <div class="d-row">
                    <div class="field" style="margin-bottom:0">
                        <label class="field-label">Species *</label>
                        <select id="np-species" class="field-input">
                            <option value="dog">Dog</option><option value="cat">Cat</option>
                            <option value="rabbit">Rabbit</option><option value="bird">Bird</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                    <div class="field" style="margin-bottom:0">
                        <label class="field-label">Gender *</label>
                        <select id="np-gender" class="field-input">
                            <option value="male">Male</option><option value="female">Female</option>
                        </select>
                    </div>
                </div>
                <div style="height:13px"></div>
                <div class="d-row">
                    <div class="field" style="margin-bottom:0"><label class="field-label">Breed *</label><input id="np-breed" class="field-input" placeholder="e.g. Labrador" /></div>
                    <div class="field" style="margin-bottom:0"><label class="field-label">Colour *</label><input id="np-colour" class="field-input" placeholder="e.g. Golden" /></div>
                </div>
                <div style="height:13px"></div>
                <div class="field"><label class="field-label">Date of Birth *</label><input id="np-dob" class="field-input" type="date" /></div>
                <label class="field-label" style="margin-bottom:8px;margin-top:4px;display:block">Upload Documents</label>
                <div id="np-photo-box" class="ubox" onclick="document.getElementById('np-photo-file').click()">
                    <input id="np-photo-file" type="file" style="display:none" accept="image/*" onchange="handleNewPetPhoto(this.files[0])">
                    <div class="ubox-icon">&#x1F4F7;</div><div class="ubox-text">Upload pet photo (JPG/PNG)</div>
                </div>
                <div id="np-cert-box" class="ubox" onclick="document.getElementById('np-cert-file').click()">
                    <input id="np-cert-file" type="file" style="display:none" accept="image/*,application/pdf" onchange="handleNewPetCert(this.files[0])">
                    <div class="ubox-icon">&#x1F4C4;</div><div class="ubox-text">Upload vaccination certificate (PDF/JPG)</div>
                </div>
                <div class="alert-box alert-warn" style="margin-top:8px">
                    <span>&#x1F6AB;</span>
                    <p>Payment is temporarily disabled. Your application will be submitted directly for ward approval.</p>
                </div>
                <button id="np-btn" type="submit" class="btn btn-primary">&#x1F43E;&nbsp;Register Pet &rarr;</button>
            </form>
        </div>
    </div>

    <!-- --- SCREEN: RENEW ------------------------------------------------- -->
    <div id="screen-renew" class="afp-screen screen d-none">
        <div class="topbar">
            <div class="topbar-left">
                <button class="back-btn" onclick="AFP.go('dashboard')">&#x2190;</button>
                <span class="topbar-title">Renew Licence</span>
            </div>
            <button class="icon-btn" title="Logout" onclick="AFP.logout()">&#x1F6AA;</button>
        </div>
        <div class="scroll p-18 pb-32">
            <div class="alert-box alert-warn"><span>&#x26A0;&#xFE0F;</span><p>Renew before expiry to avoid penalty fees.</p></div>
            <form id="renew-form" novalidate>
                <div class="field">
                    <label class="field-label">Select pet *</label>
                    <select id="renew-pet" class="field-input"><option value="">Select pet...</option></select>
                </div>
                <div id="renew-err"></div>
                <div id="renew-details" style="display:none"></div>
                <div class="fee-row">
                    <div><div style="color:var(--tx2);font-size:13px">Renewal fee</div><div style="font-weight:600">&#x20B9; 150</div></div>
                    <div style="text-align:right"><div style="color:var(--tx2);font-size:13px">New validity</div><div style="font-weight:600">1 year</div></div>
                </div>
                <button id="renew-btn" type="submit" class="btn btn-primary">Renew Licence &#x2192;</button>
            </form>
        </div>
    </div>

    <!-- --- SCREEN: REPORT PET ------------------------------------------- -->
    <div id="screen-reportPet" class="afp-screen screen d-none">
        <div class="topbar">
            <div class="topbar-left">
                <button class="back-btn" onclick="AFP.go('dashboard')">&#x2190;</button>
                <span class="topbar-title">Report a Pet</span>
            </div>
            <button class="icon-btn" title="Logout" onclick="AFP.logout()">&#x1F6AA;</button>
        </div>
        <div class="scroll p-18 pb-32">
            <div class="alert-box alert-warn"><span>&#x26A0;&#xFE0F;</span><p>Report a stray, lost, or unlicensed pet. Ward officer will be notified.</p></div>
            <form id="rp-form" novalidate>
                <div class="field">
                    <label class="field-label">Report type *</label>
                    <select id="rp-type" class="field-input">
                        <option value="stray">Stray / abandoned pet</option>
                        <option value="lost">Lost pet</option>
                        <option value="unlicensed">Unlicensed pet</option>
                        <option value="cruelty">Animal cruelty</option>
                    </select>
                </div>
                <div class="field"><label class="field-label">Last seen address *</label><input id="rp-addr" class="field-input" placeholder="Street / landmark" /></div>
                <div class="field"><label class="field-label">Your mobile *</label><input id="rp-mobile" class="field-input" type="tel" placeholder="+91 98765 43210" /></div>
                <button id="rp-btn" type="submit" class="btn btn-primary">Submit Report</button>
            </form>
        </div>
    </div>

    <!-- --- SCREEN: TRANSFER ---------------------------------------------- -->
    <div id="screen-newOwner" class="afp-screen screen d-none">
        <div class="topbar">
            <div class="topbar-left">
                <button class="back-btn" onclick="AFP.go('dashboard')">&#x2190;</button>
                <span class="topbar-title">Transfer Ownership</span>
            </div>
            <button class="icon-btn" title="Logout" onclick="AFP.logout()">&#x1F6AA;</button>
        </div>
        <div class="scroll p-18 pb-32">
            <div class="alert-box alert-info"><span>&#x2139;&#xFE0F;</span><p>Transfer requires ward approval. Both owners must be registered.</p></div>
            <form id="to-form" novalidate>
                <div class="field">
                    <label class="field-label">Select pet *</label>
                    <select id="to-pet" class="field-input"><option value="">Select pet…</option></select>
                </div>
                <div class="field"><label class="field-label">New owner's full name *</label><input id="to-name" class="field-input" placeholder="Full name" /></div>
                <div class="field"><label class="field-label">New owner's mobile *</label><input id="to-mobile" class="field-input" type="tel" placeholder="Registered mobile" /></div>
                <div class="fee-row">
                    <span class="fee-lbl">Transfer fee</span>
                    <span class="fee-val">&#x20B9; 100</span>
                </div>
                <button id="to-btn" type="submit" class="btn btn-primary">Submit Transfer &#x2192;</button>
            </form>
        </div>
    </div>

    <!-- --- SCREEN: SEARCH DOCTOR ----------------------------------------- -->
    <div id="screen-searchDoctor" class="afp-screen screen d-none">
        <div class="topbar">
            <div class="topbar-left">
                <button class="back-btn" onclick="AFP.go('dashboard')">&#x2190;</button>
                <span class="topbar-title">Find a Vet</span>
            </div>
            <button class="icon-btn" title="Logout" onclick="AFP.logout()">&#x1F6AA;</button>
        </div>
        <div style="padding:13px;background:#fff;border-bottom:1px solid var(--bd)">
            <div class="search-wrap">
                <span class="search-icon">&#x1F50D;</span>
                <input id="searchdoc-q" class="field-input" placeholder="Name, clinic, specialization…"
                    oninput="doSearchDoctor()" style="padding-left:34px" />
            </div>
            <div class="chips">
                <button class="chip searchdoc-chip active" data-city="" onclick="setDoctorFilter(this,'')">All</button>
                <button class="chip searchdoc-chip" data-city="1" onclick="setDoctorFilter(this,'1')">&#x1F4CD; Jaipur</button>
                <button class="chip searchdoc-chip" data-city="2" onclick="setDoctorFilter(this,'2')">&#x1F4CD; Delhi</button>
